datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS ──────────────────────────────────────────────

enum ProductStatus {
  TERSEDIA
  TERJUAL
  DRAFT
}

enum TipeItem {
  ASET
  JASA
}

// ─── MODELS ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("SUPER_ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  products  Product[]
  type      String   @default("umum") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tipeItem    TipeItem      @default(ASET)
  price       Decimal       @db.Decimal(15, 2)
  description String        @db.Text
  location    String
  status      ProductStatus @default(DRAFT)
  mainImage   String
  images      String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model CompanyProfile {
  id          String   @id @default(cuid())
  tentang     String   @default("") @db.Text
  visi        String   @default("") @db.Text
  misi        String   @default("") @db.Text
  keunggulan  String   @default("") @db.Text
  updatedAt   DateTime @updatedAt

  @@map("company_profiles")
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  ctaText     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

model WebSetting {
  id           String   @id @default(cuid())
  whatsapp     String?
  email        String?
  address      String?
  sosmedLinks  Json     @default("{}")
  updatedAt    DateTime @updatedAt

  @@map("web_settings")
}
